{
  "name": "creo-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test packages/creo/src/",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "version:patch": "bun run scripts/version.ts patch",
    "version:minor": "bun run scripts/version.ts minor",
    "version:major": "bun run scripts/version.ts major",
    "publish:all": "bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
