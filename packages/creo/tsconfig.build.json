{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,

    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/index.ts", "src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/_profile.ts"]
}
